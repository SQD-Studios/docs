---
import Default from "@astrojs/starlight/components/Footer.astro";
import { Icon } from "@astrojs/starlight/components";
---

<Default><slot /></Default>
<div>
    <p class="footer-item">
        Copyright © {new Date().getFullYear()} SQD Studios Contributors. See our progress at our <a href="https://github.com/SQD-Studios" target="_blank">GitHub</a>
    </p>
    <p class="footer-item muted">
        This website is not an official Minecraft website and is not associated with Mojang Studios or Microsoft.
    </p>
</div>

<style>
    .footer-item {
        text-align: center;
        font-size: var(--sl-text-2xs);
        color: var(--sl-color-gray-2);
        margin-bottom: 0.25rem;
    }

    .footer-item a:not(:hover) {
        text-decoration: none;
    }

    .icon {
        color: var(--sl-color-orange);
    }

    .muted {
        color: var(--sl-color-gray-3);
    }
</style>