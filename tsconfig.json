{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "es2016",
    //"module": "commonjs",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
